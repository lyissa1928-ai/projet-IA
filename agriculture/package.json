{
  "name": "agriculture-intelligente",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.14.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm run docker:up && concurrently -n web,api -c blue,green \"pnpm dev:web\" \"pnpm dev:api\"",
    "dev:no-docker": "concurrently -n web,api -c blue,green \"pnpm dev:web\" \"pnpm dev:api\"",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "dev:iot": "pnpm --filter iot dev",
    "build": "pnpm run build:shared && pnpm run build:web && pnpm run build:api",
    "build:shared": "pnpm --filter @agriculture/shared build",
    "build:web": "pnpm --filter web build",
    "build:api": "pnpm --filter api build",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test --if-present",
    "typecheck": "pnpm -r run typecheck --if-present",
    "db:migrate": "pnpm --filter api exec prisma migrate deploy",
    "db:migrate:dev": "pnpm --filter api exec prisma migrate dev",
    "db:seed": "pnpm --filter api exec prisma db seed",
    "db:studio": "pnpm --filter api exec prisma studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "~5.6.0"
  }
}
