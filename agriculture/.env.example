# =============================================================================
# AGRICULTURE INTELLIGENTE - Configuration d'environnement
# =============================================================================
# Copier vers .env et remplir les valeurs

# -----------------------------------------------------------------------------
# API (NestJS)
# -----------------------------------------------------------------------------
NODE_ENV=development
API_PORT=4000
API_URL=http://localhost:4000

# JWT
JWT_ACCESS_SECRET=change-me-in-production-use-long-random-string
JWT_REFRESH_SECRET=change-me-in-production-use-different-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Database (PostgreSQL)
DATABASE_URL=postgresql://agriculture:agriculture@localhost:5432/agriculture

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# CORS (frontend URL)
CORS_ORIGIN=http://localhost:3000

# -----------------------------------------------------------------------------
# Web (Next.js)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME=Agriculture Intelligente
# Déconnexion après inactivité (minutes, défaut: 30)
NEXT_PUBLIC_SESSION_TIMEOUT_MINUTES=30

# -----------------------------------------------------------------------------
# Météo (OpenWeather)
# -----------------------------------------------------------------------------
WEATHER_PROVIDER=openweather
OPENWEATHER_API_KEY=
WEATHER_REFRESH_MINUTES=30
WEATHER_CACHE_TTL_SECONDS=1800

# -----------------------------------------------------------------------------
# Recommandations (Sprint 3)
# -----------------------------------------------------------------------------
ENGINE_VERSION=rules-v1.0
RECO_DEFAULT_HISTORY_DAYS=30
RECO_THRESHOLD=60

# -----------------------------------------------------------------------------
# Alertes (Sprint 4)
# -----------------------------------------------------------------------------
ALERTS_EVALUATION_MINUTES=30
ALERTS_DEFAULT_COOLDOWN_HOURS=24
ALERTS_BATCH_SIZE=200

# -----------------------------------------------------------------------------
# IoT (optionnel)
# -----------------------------------------------------------------------------
IOT_MQTT_BROKER=mqtt://localhost:1883
IOT_MQTT_ENABLED=false

# -----------------------------------------------------------------------------
# Staging / Production (override dans deploy/)
# -----------------------------------------------------------------------------
# API_URL=https://api.domain.tld
# CORS_ORIGIN=https://app.domain.tld
# NEXT_PUBLIC_API_URL=https://api.domain.tld
